{
  "name": "CompetitorStat",
  "type": "object",
  "properties": {
    "category_id": {
      "type": "string",
      "description": "Reference to Category"
    },
    "rival_id": {
      "type": "string",
      "description": "Reference to CompetitorProfile"
    },
    "total_value": {
      "type": "number",
      "description": "Overall total for this category",
      "default": 0
    }
  },
  "required": [
    "category_id"
  ]
}