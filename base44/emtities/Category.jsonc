{
  "name": "Category",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Category name (e.g. kary, tickety, centrum)"
    },
    "order": {
      "type": "number",
      "description": "Display order"
    },
    "color": {
      "type": "string",
      "description": "Hex color for charts"
    }
  },
  "required": [
    "name"
  ]
}