{
  "name": "MonthlyGoal",
  "type": "object",
  "properties": {
    "month": {
      "type": "string",
      "description": "Month in YYYY-MM format"
    },
    "category_id": {
      "type": "string",
      "description": "Reference to Category"
    },
    "target": {
      "type": "number",
      "description": "Monthly goal target value",
      "default": 0
    }
  },
  "required": [
    "month",
    "category_id",
    "target"
  ]
}