{
  "name": "YearlyGoal",
  "type": "object",
  "properties": {
    "year": {
      "type": "string",
      "description": "Year in YYYY format"
    },
    "category_id": {
      "type": "string",
      "description": "Reference to Category"
    },
    "target": {
      "type": "number",
      "description": "Yearly goal target value",
      "default": 0
    }
  },
  "required": [
    "year",
    "category_id",
    "target"
  ]
}